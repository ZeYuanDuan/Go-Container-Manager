# Copy to .env and adjust as needed
# postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://aidms:aidms@localhost:5432/aidms?sslmode=disable
JWT_SECRET=your-super-secret-key-at-least-32-chars
STORAGE_ROOT=./storage/uploads
SERVER_PORT=8080

# Optional
# LOG_LEVEL=info
# WORKER_POOL_SIZE=4
# STORAGE_HOST_PATH - for Docker: set to host path of storage (e.g. $(pwd)/storage/uploads)
#   make docker-up sets this automatically
